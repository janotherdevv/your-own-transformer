<mxGraphModel adaptiveColors="auto" dx="1422" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- START -->
    <mxCell id="s" value="main.py" style="ellipse;whiteSpace=wrap;fillColor=#333333;fontColor=#FFFFFF;strokeColor=#333333;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="220" y="30" width="140" height="40" as="geometry"/>
    </mxCell>

    <!-- INIT - Blue -->
    <mxCell id="n1" value="Detect device" style="rounded=1;whiteSpace=wrap;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="180" y="110" width="220" height="46" as="geometry"/>
    </mxCell>

    <mxCell id="n2" value="Create Transformer" style="rounded=1;whiteSpace=wrap;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="180" y="196" width="220" height="46" as="geometry"/>
    </mxCell>

    <!-- DECISION - Yellow -->
    <mxCell id="d1" value="Checkpoint?" style="rhombus;whiteSpace=wrap;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="195" y="290" width="190" height="90" as="geometry"/>
    </mxCell>

    <!-- YES branch - Green -->
    <mxCell id="n3" value="load_checkpoint()" style="rounded=1;whiteSpace=wrap;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="480" y="310" width="190" height="50" as="geometry"/>
    </mxCell>

    <!-- NO branch - Green then Orange -->
    <mxCell id="n4" value="load_data()" style="rounded=1;whiteSpace=wrap;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="180" y="430" width="220" height="46" as="geometry"/>
    </mxCell>

    <mxCell id="n5" value="train()" style="rounded=1;whiteSpace=wrap;fillColor=#FFE6CC;strokeColor=#D6B656;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="180" y="516" width="220" height="46" as="geometry"/>
    </mxCell>

    <mxCell id="n6" value="save_checkpoint()" style="rounded=1;whiteSpace=wrap;fillColor=#FFE6CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="180" y="602" width="220" height="46" as="geometry"/>
    </mxCell>

    <!-- POST MERGE - Blue -->
    <mxCell id="n7" value="Build idx_to_word" style="rounded=1;whiteSpace=wrap;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="180" y="720" width="220" height="46" as="geometry"/>
    </mxCell>

    <!-- INFERENCE - Purple -->
    <mxCell id="n8" value="Demo translations" style="rounded=1;whiteSpace=wrap;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="180" y="806" width="220" height="46" as="geometry"/>
    </mxCell>

    <mxCell id="n9" value="Interactive mode" style="rounded=1;whiteSpace=wrap;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="180" y="892" width="220" height="46" as="geometry"/>
    </mxCell>

    <!-- END -->
    <mxCell id="end" value="salir" style="ellipse;whiteSpace=wrap;fillColor=#333333;fontColor=#FFFFFF;strokeColor=#333333;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="230" y="1010" width="120" height="36" as="geometry"/>
    </mxCell>

    <!-- translate() sub-process container - Purple -->
    <mxCell id="c1" value="translate()" style="swimlane;startSize=26;fillColor=#F3E8F9;strokeColor=#9673A6;fontSize=12;fontStyle=1;rounded=1;arcSize=8;swimlaneLine=0;" vertex="1" parent="1">
      <mxGeometry x="480" y="770" width="220" height="200" as="geometry"/>
    </mxCell>

    <mxCell id="t1" value="encode()" style="rounded=1;whiteSpace=wrap;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;" vertex="1" parent="c1">
      <mxGeometry x="10" y="36" width="200" height="32" as="geometry"/>
    </mxCell>

    <mxCell id="t2" value="Encoder forward" style="rounded=1;whiteSpace=wrap;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;" vertex="1" parent="c1">
      <mxGeometry x="10" y="78" width="200" height="32" as="geometry"/>
    </mxCell>

    <mxCell id="t3" value="Decoder loop (greedy)" style="rounded=1;whiteSpace=wrap;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;" vertex="1" parent="c1">
      <mxGeometry x="10" y="120" width="200" height="32" as="geometry"/>
    </mxCell>

    <mxCell id="t4" value="idx to words" style="rounded=1;whiteSpace=wrap;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;" vertex="1" parent="c1">
      <mxGeometry x="10" y="162" width="200" height="32" as="geometry"/>
    </mxCell>

    <!-- MAIN FLOW EDGES -->
    <mxCell id="e1" edge="1" parent="1" source="s" target="n1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="e2" edge="1" parent="1" source="n1" target="n2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="e3" edge="1" parent="1" source="n2" target="d1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="e4" value="Si" edge="1" parent="1" source="d1" target="n3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontStyle=1;fontSize=11;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="e5" value="No" edge="1" parent="1" source="d1" target="n4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontStyle=1;fontSize=11;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="e6" edge="1" parent="1" source="n4" target="n5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="e7" edge="1" parent="1" source="n5" target="n6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="e8" edge="1" parent="1" source="n6" target="n7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- load_checkpoint merge back to main flow -->
    <mxCell id="e9" edge="1" parent="1" source="n3" target="n7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="575" y="690"/>
          <mxPoint x="290" y="690"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <mxCell id="e10" edge="1" parent="1" source="n7" target="n8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="e11" edge="1" parent="1" source="n8" target="n9" style="edgeStyle=orthogonalEdgeStyle;rounded=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="e12" edge="1" parent="1" source="n9" target="end" style="edgeStyle=orthogonalEdgeStyle;rounded=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Interactive mode calls translate() -->
    <mxCell id="e13" edge="1" parent="1" source="n9" target="c1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;dashed=1;strokeColor=#9673A6;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.7;entryDx=0;entryDy=0;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Demo translations also calls translate() -->
    <mxCell id="e14" edge="1" parent="1" source="n8" target="c1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;dashed=1;strokeColor=#9673A6;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Edges inside translate() container -->
    <mxCell id="te1" edge="1" parent="c1" source="t1" target="t2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673A6;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="te2" edge="1" parent="c1" source="t2" target="t3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673A6;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="te3" edge="1" parent="c1" source="t3" target="t4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673A6;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>
